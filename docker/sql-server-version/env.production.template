# Track.IO - Variables de Entorno para Producción (SQL Server)
# Copia este archivo a .env.production y configura los valores apropiados

# ==========================================
# SQL Server Configuration (PRODUCCIÓN)
# ==========================================

# Contraseña del usuario SA (OBLIGATORIO - debe ser segura)
# Mínimo 8 caracteres, debe contener mayúsculas, minúsculas, números y caracteres especiales
MSSQL_SA_PASSWORD_PROD=YourStrong@ProductionPassword123

# Usuario de base de datos (default: sa)
MSSQL_USER_PROD=sa

# Nombre de la base de datos de producción
MSSQL_DB_PROD=track_io_prod

# Puerto de SQL Server (default: 1433)
MSSQL_PORT_PROD=1433

# Edición de SQL Server (Express, Developer, Standard, Enterprise, EnterpriseCore)
# Express es gratuita pero tiene limitaciones
MSSQL_PID=Express

# Configuración SSL para SQL Server
MSSQL_ENCRYPT_PROD=true
MSSQL_TRUST_SERVER_CERTIFICATE_PROD=false

# ==========================================
# Backend Configuration
# ==========================================

# Puerto del backend (default: 3000)
BACKEND_PORT_PROD=3000

# Origen CORS permitido (OPCIONAL)
# Si no se especifica, se detecta automáticamente incluyendo:
# - http://localhost:80 (acceso local)
# - http://[IP_SERVIDOR]:80 (acceso desde red local)
# Para agregar orígenes adicionales, separar con coma:
# CORS_ORIGIN_PROD=http://mi-dominio.com,https://mi-dominio.com

# Nivel de logging (error, warn, info, debug)
LOG_LEVEL=info

# Módulos del sistema
MODULE_MEASUREMENTS_ENABLED=true
MODULE_SIGNALS_ENABLED=true

# ==========================================
# Nginx Configuration
# ==========================================

# Puerto HTTP (default: 80)
NGINX_PORT_PROD=80

# Puerto HTTPS (default: 443)
NGINX_SSL_PORT_PROD=443

# URL del backend para el frontend (se genera automáticamente)
# VITE_API_URL_PROD=http://localhost:3000

# ==========================================
# Security Recommendations
# ==========================================

# En producción, considera:
# 1. Usar certificados SSL válidos
# 2. Configurar firewall para limitar acceso
# 3. Usar contraseñas fuertes y únicas
# 4. Habilitar backups automáticos
# 5. Configurar monitoreo y alertas
# 6. Usar variables de entorno seguras (no commitees .env.production)

# ==========================================
# Backup Configuration
# ==========================================

# Directorio para backups (relativo a docker/sql-server-version/)
BACKUP_DIR=./backups

# Horario de backups automáticos (formato cron)
# BACKUP_SCHEDULE=0 2 * * *  # 2 AM diario
