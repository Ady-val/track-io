# SQL Server Configuration
# Evitar @ y # en la contraseña (rompen parsing de URLs)
MSSQL_SA_PASSWORD=YourStrongPassword123!
MSSQL_DB=track_io
MSSQL_PORT=1433

# Database Connection Configuration
DATABASE_TYPE=mssql
DATABASE_HOST=track_io_sql_server
DATABASE_PORT=1433
DATABASE_USERNAME=sa
DATABASE_PASSWORD=YourStrongPassword123!
DATABASE_NAME=track_io

# Database Connection String (for application use)
# Format: mssql://username:password@host:port/database
DATABASE_URL=mssql://sa:YourStrongPassword123!@track_io_sql_server:1433/track_io

# Application Configuration
NODE_ENV=production
PORT=3000
CORS_ORIGIN=*

# System Module Configuration
MODULE_MEASUREMENTS_ENABLED=true
MODULE_SIGNALS_ENABLED=true

# IP del servidor en la red local (recomendado para que otros equipos usen el dashboard).
# Si la dejas vacia, run.sh intenta detectarla automaticamente (Linux).
# Ejemplo: HOST_IP=192.168.1.50
HOST_IP=

# Frontend (run.sh genera .env.host con VITE_API_URL a partir de HOST_IP al hacer pnpm build)
# Virtual Device: http://localhost/virtual-device/ (integrado en nginx)
# Token opcional para consumir endpoints protegidos desde virtual-device
VITE_AUTH_TOKEN=
