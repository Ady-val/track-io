# Track.IO - Docker Ignore File
# This file specifies which files and directories to exclude from Docker build context

# Node.js dependencies - NEVER copy from host, always install in container
node_modules/
**/node_modules/
**/node_modules/**
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.pnpm/

# Build artifacts - These will be generated during build
dist/
build/
.next/
.nuxt/

# Environment files - Use docker-compose environment variables instead
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Log files
logs/
*.log

# System files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE and editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temporary files
*.tmp
*.temp
.cache/

# Version control
.git/
.gitignore

# Docker files - Don't include Docker files in build context
Dockerfile*
docker-compose*
.dockerignore

# Documentation files
README.md
*.md

# Windows specific files
Thumbs.db
ehthumbs.db
Desktop.ini

# Backup files
*.backup
*.bak