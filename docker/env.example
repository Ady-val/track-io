# Track.IO - Environment Variables Example
# Copy this file to .env and customize as needed

# Database Configuration
# Development: Use track_iq_dev for local development
# Production: Use track_io for production deployment
POSTGRES_DB=track_io
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Environment-specific database names:
# - For local development: POSTGRES_DB=track_iq_dev
# - For production: POSTGRES_DB=track_io

# Service Ports
BACKEND_PORT=3000
FRONTEND_PORT=80
VIRTUAL_DEVICE_PORT=8080

# Network Configuration
# Set this to your machine's IP address for network access
# Leave empty or set to 'localhost' for local-only access
HOST_IP=

# Node.js Environment
NODE_ENV=production