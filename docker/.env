# Database
POSTGRES_DB=track_io
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=3000
NODE_ENV=production

# Módulos del sistema: trabajando sobre signals, measurements deshabilitado.
MODULE_SIGNALS_ENABLED=true
MODULE_MEASUREMENTS_ENABLED=false

# Análisis de patrones con IA en Reportes (§insights). Requiere ANTHROPIC_API_KEY
# para funcionar aunque el flag esté en true (si falta, /insights/health
# reporta modelConfigured=false y el botón se deshabilita en el frontend).
MODULE_INSIGHTS_ENABLED=true
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
INSIGHTS_MAX_TOKENS=4000
INSIGHTS_MAX_RANGE_DAYS=90
INSIGHTS_TOP_SIGNALS=10
INSIGHTS_CACHE_TTL_MINUTES=1440
INSIGHTS_MIN_SAMPLE=20

# Frontend
FRONTEND_PORT=80

# PgAdmin
PGADMIN_EMAIL=admin@trackio.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8080
