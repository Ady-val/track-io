{
  "name": "vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "lint:check": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:env:start": "node scripts/start-test-env.js",
    "test:env:stop": "node scripts/stop-test-env.js",
    "dev:test": "cross-env VITE_API_URL=http://localhost:3001 vite",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:devices": "cypress run --spec 'cypress/e2e/devices/**/*.cy.ts'",
    "cypress:run:catalogs": "cypress run --spec 'cypress/e2e/catalogs/**/*.cy.ts'",
    "test:e2e": "cypress run",
    "test:e2e:devices": "cypress run --spec 'cypress/e2e/devices/**/*.cy.ts'",
    "test:e2e:catalogs": "cypress run --spec 'cypress/e2e/catalogs/**/*.cy.ts'"
  },
  "dependencies": {
    "@heroui/badge": "^2.2.17",
    "@heroui/button": "2.2.27",
    "@heroui/card": "^2.2.25",
    "@heroui/chip": "^2.2.22",
    "@heroui/code": "2.2.21",
    "@heroui/dropdown": "2.3.27",
    "@heroui/input": "2.4.28",
    "@heroui/kbd": "2.2.22",
    "@heroui/link": "2.2.23",
    "@heroui/modal": "^2.2.24",
    "@heroui/navbar": "2.2.25",
    "@heroui/select": "^2.4.28",
    "@heroui/snippet": "2.2.28",
    "@heroui/spinner": "^2.2.24",
    "@heroui/switch": "2.2.24",
    "@heroui/system": "2.4.23",
    "@heroui/theme": "2.4.23",
    "@heroui/use-theme": "2.1.10",
    "@hookform/resolvers": "^5.2.2",
    "@react-aria/visually-hidden": "3.8.28",
    "@react-types/shared": "3.32.1",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/vite": "4.1.11",
    "@tanstack/react-query": "^5.90.5",
    "axios": "^1.12.2",
    "chart.js": "^4.5.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-adapter-dayjs-4": "^1.0.0",
    "clsx": "2.1.1",
    "framer-motion": "11.18.2",
    "dayjs": "^1.11.11",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.66.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "6.23.0",
    "socket.io-client": "^4.8.1",
    "tailwind-variants": "3.1.1",
    "tailwindcss": "4.1.11",
    "zod": "^4.1.12",
    "chartjs-adapter-dayjs": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.8",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.25.1",
    "@mswjs/data": "^0.16.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "20.5.7",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "@vitejs/plugin-react": "4.7.0",
    "baseline-browser-mapping": "^2.9.16",
    "cross-env": "^10.1.0",
    "cypress": "^13.17.0",
    "eslint": "9.25.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "16.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "msw": "^2.12.4",
    "postcss": "8.5.6",
    "prettier": "3.5.3",
    "ts-jest": "^29.4.6",
    "ts-jest-mock-import-meta": "^1.3.1",
    "typescript": "5.6.3",
    "undici": "^7.16.0",
    "vite": "6.0.11",
    "vite-tsconfig-paths": "5.1.4"
  }
}
