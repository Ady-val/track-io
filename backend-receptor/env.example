# =============================================================================
# Track.IO Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust the values for your environment
#
# IMPORTANT: The .env file is gitignored and should NEVER be committed
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# For local development connecting to Docker database:
# - Use localhost as host
# - Database is exposed on port 5432
# - Default credentials are postgres/postgres
# - Database name is track_io (matches docker-compose.yml)

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=track_io

# Alternative: Use DATABASE_URL (overrides individual settings above)
# Uncomment to use:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/track_io

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allow requests from these origins (comma-separated)
# For development with Vite dev servers:
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost

# For production (allow all):
# CORS_ORIGIN=*

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Secret key for JWT token signing
# IMPORTANT: Change this to a strong, random secret in production!
# Generate a secure secret with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# 1. Make sure Docker is running with: cd docker && start.bat
# 2. This will start PostgreSQL on localhost:5432
# 3. Run migrations: npm run migration:run
# 4. Start backend in dev mode: npm run start:dev
# 5. Backend will be available at http://localhost:3000
#
# Common ports:
# - Backend API: 3000
# - Dashboard dev: 5173
# - Virtual Device dev: 5174
# - PostgreSQL: 5432
# =============================================================================