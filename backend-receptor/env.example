# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=track_io
# Modbus defaults
MODBUS_HOST=host.docker.internal
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_CONNECT_TIMEOUT_MS=2000
MODBUS_REQUEST_TIMEOUT_MS=1500
# Default register to toggle tower light (1|2|3)
TORRETA_REGISTER=1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/track_io

# Application Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:5174