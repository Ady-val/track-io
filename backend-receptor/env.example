# =============================================================================
# Track.IO Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust the values for your environment
#
# IMPORTANT: The .env file is gitignored and should NEVER be committed
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Development: track_iq_dev (use: pnpm run db:start)
# Production: track_io (use: docker/start.bat or start.sh)

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=track_iq_dev

# Alternative: Use DATABASE_URL (overrides individual settings above)
# Uncomment to use:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/track_io

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Allow requests from these origins (comma-separated)
# For development with Vite dev servers:
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost

# For production (allow all):
# CORS_ORIGIN=*

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Secret key for JWT token signing
# IMPORTANT: Change this to a strong, random secret in production!
# Generate a secure secret with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# =============================================================================
# SYSTEM MODULES CONFIGURATION
# =============================================================================
# Enable or disable system modules (signals and measurements)
# Values: 'true' or 'false' (default: 'true')
MODULE_MEASUREMENTS_ENABLED=true
MODULE_SIGNALS_ENABLED=true

# =============================================================================
# INITIAL ADMIN USER (migration CreateAdminUser)
# =============================================================================
# Used by the CreateAdminUser migration to bootstrap the first admin user.
# If either is empty/undefined the migration is skipped (no admin is created).
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=change-me-in-production

# =============================================================================
# NODE-RED EVENTS ENDPOINT
# =============================================================================
# URL where outbound payloads (torreta / alert messages) are POSTed.
# Default (unset): http://localhost:1880/events
# In Docker set this to the host reachable from the container, e.g.:
# NODE_RED_EVENTS_URL=http://host.docker.internal:1880/events
NODE_RED_EVENTS_URL=http://localhost:1880/events

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# 1. Start development database: pnpm run db:start
# 2. Start backend in dev mode: pnpm run start:dev
# 3. Backend will be available at http://localhost:3000
# 4. TypeORM automatically creates tables in development
#
# Common ports:
# - Backend API: 3000
# - Dashboard dev: 5173
# - Virtual Device dev: 5174
# - PostgreSQL: 5432
# =============================================================================